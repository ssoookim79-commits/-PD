{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project item",
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["Music", "Entertainment"] },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "thumbnailUrl": { "type": "string", "format": "url" },
        "videos": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string", "format": "url" }
            }
          }
        },
        "description": { "type": "string" },
        "role": { "type": "string" },
        "points": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "number" },
        "isFeatured": { "type": "boolean", "description": "Whether to show this project on the home page" }
      },
      "required": ["category", "type", "title", "thumbnailUrl", "description", "role", "points", "videos"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "A collection of portfolio projects"
    }
  }
}
