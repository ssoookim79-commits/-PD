{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project item",
      "type": "object",
      "properties": {
        "category": { "type": "string", "enum": ["Music", "Entertainment"] },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "videoUrl": { "type": "string", "format": "url" },
        "description": { "type": "string" },
        "role": { "type": "string" },
        "points": { "type": "array", "items": { "type": "string" } },
        "order": { "type": "number" }
      },
      "required": ["category", "type", "title", "videoUrl", "description", "role", "points"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "A collection of portfolio projects"
    }
  }
}
