rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Document ID: auto-generated or custom
    // Fields:
    //   - category: string (required, enum: ["Music", "Entertainment"])
    //   - type: string (required)
    //   - title: string (required, max 100 chars)
    //   - videoUrl: string (required, valid URL)
    //   - description: string (required, max 1000 chars)
    //   - role: string (required)
    //   - points: list (required, max 10 items, each string max 200 chars)
    //   - order: number (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          request.auth.token.email == "ssoookim79@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidProject(data) {
      return data.keys().hasAll(['category', 'type', 'title', 'description', 'role', 'points']) &&
             data.category in ['Music', 'Entertainment'] &&
             data.type is string && data.type.size() > 0 && data.type.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             (!('thumbnailUrl' in data) || (data.thumbnailUrl is string && data.thumbnailUrl.matches("^https?://.*"))) &&
             (!('videoUrl' in data) || (data.videoUrl is string && data.videoUrl.matches("^https?://.*"))) &&
             data.description is string && data.description.size() < 1000 &&
             data.role is string && data.role.size() < 200 &&
             data.points is list && data.points.size() <= 10 &&
             (!('videos' in data) || (data.videos is list && data.videos.size() <= 20));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /projects/{projectId} {
      allow read: if true; // Publicly readable for portfolio
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
